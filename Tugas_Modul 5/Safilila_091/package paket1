package paket1;

public class Orang {

    public String nama = "Safila";      // public
    protected int umur = 19;            // protected
    String alamat = "Surabaya";         // default
    private String password = "12345";  // private

    public void tampilPublic() {
        System.out.println("Nama : " + nama);
    }

    protected void tampilProtected() {
        System.out.println("Umur : " + umur);
    }

    void tampilDefault() {
        System.out.println("Alamat : " + alamat);
    }

    private void tampilPrivate() {
        System.out.println("Password : " + password);
    }

    public void aksesPrivate() {
        tampilPrivate();
    }
}
