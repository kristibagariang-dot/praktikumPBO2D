abstract class Pegawai {

    String nik;
    String nama;
    int kehadiran;
    double gaji;

    public Pegawai(String nik, String nama, int kehadiran, double gaji) {
        this.nik = nik;
        this.nama = nama;
        this.kehadiran = kehadiran;
        this.gaji = gaji;
    }

    public abstract double rekapGaji();

    public abstract void tampilData();
}

class PegawaiKontrak extends Pegawai {

    int masaKontrak;

    public PegawaiKontrak(String nik, String nama,
                          int masaKontrak,
                          int kehadiran,
                          double gaji) {

        super(nik, nama, kehadiran, gaji);
        this.masaKontrak = masaKontrak;
    }

    @Override
    public double rekapGaji() {
        double uangMakan = kehadiran * 15000;
        return gaji + uangMakan;
    }

    @Override
    public void tampilData() {

        double uangMakan = kehadiran * 15000;

        System.out.println("\n=== DATA PEGAWAI KONTRAK ===");
        System.out.println("NIK           : " + nik);
        System.out.println("Nama          : " + nama);
        System.out.println("Masa Kontrak  : " + masaKontrak + " bulan");
        System.out.println("Kehadiran     : " + kehadiran);
        System.out.println("Uang Makan    : " + uangMakan);
        System.out.println("Gaji Pokok    : " + gaji);
        System.out.println("Gaji Bersih   : " + rekapGaji());
    }
}

class PegawaiTetap extends Pegawai {

    final double tunjangan = 630000;

    public PegawaiTetap(String nik, String nama,
                        int kehadiran,
                        double gaji) {

        super(nik, nama, kehadiran, gaji);
    }

    @Override
    public double rekapGaji() {
        double uangMakan = kehadiran * 15000;
        return gaji + uangMakan + tunjangan;
    }

    @Override
    public void tampilData() {

        double uangMakan = kehadiran * 15000;

        System.out.println("\n=== DATA PEGAWAI TETAP ===");
        System.out.println("NIK           : " + nik);
        System.out.println("Nama          : " + nama);
        System.out.println("Kehadiran     : " + kehadiran);
        System.out.println("Tunjangan     : " + tunjangan);
        System.out.println("Uang Makan    : " + uangMakan);
        System.out.println("Gaji Pokok    : " + gaji);
        System.out.println("Gaji Bersih   : " + rekapGaji());
    }
}

public class Main {
    public static void main(String[] args) {

        Pegawai p1 = new PegawaiTetap(
                "PT001",
                "Suci Amalia",
                25,
                4000000);

        Pegawai p2 = new PegawaiKontrak(
                "PK001",
                "Andi",
                12,
                22,
                3000000);

        p1.tampilData();
        p2.tampilData();
    }
}
